---



import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
import type { Lang } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = 'Portfolio',
  description = 'Personal portfolio site',
  lang = 'ja',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- 言語自動リダイレクト（初回セッションのみ） -->
    <script is:inline>
      (() => {
        if (!sessionStorage.getItem('lang-redirected')) {
          sessionStorage.setItem('lang-redirected', '1');
          const isJa     = (navigator.language || '').toLowerCase().startsWith('ja');
          const isEnPage = location.pathname.startsWith('/en');
          if (isJa && isEnPage)   { location.replace('/');    }
          else if (!isJa && !isEnPage) { location.replace('/en/'); }
        }
      })();
    </script>

    <!-- テーマ初期化（描画前に実行してFOUCを防止） -->
    <script is:inline>
      (() => {
        var stored = sessionStorage.getItem('theme');
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        var theme = stored || (mq.matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);

        mq.addEventListener('change', (e) => {
          if (!sessionStorage.getItem('theme')) {
            document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
            window.dispatchEvent(new CustomEvent('theme-change'));
          }
        });
      })();
    </script>
  </head>
  <body>
    <div id="particles-js"></div>
    <Navigation lang={lang} />
    <main>
      <slot />
    </main>

    <!-- Scroll animation -->
    <script is:inline>
      const _observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              _observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => { _observer.observe(el); });
    </script>

    <!-- Modal management — single event delegation for all dialogs on the page -->
    <script is:inline>
      (function () {
        document.addEventListener('cancel', function (e) {
          if (e.target.tagName === 'DIALOG') document.body.style.overflow = '';
        }, true);

        document.addEventListener('click', function (e) {
          var el = e.target;

          /* Open */
          var opener = el.closest('[data-modal-open]');
          if (opener) {
            var id = opener.getAttribute('data-modal-open');
            var dlg = document.getElementById(id);
            if (dlg && !dlg.open) {
              dlg.showModal();
              document.body.style.overflow = 'hidden';
            }
            return;
          }

          /* Close via ✕ button */
          var closer = el.closest('[data-modal-close]');
          if (closer) {
            var d = closer.closest('dialog');
            if (d) { d.close(); document.body.style.overflow = ''; }
            return;
          }

          /* Close on backdrop (click lands directly on <dialog>) */
          if (el.tagName === 'DIALOG') {
            el.close();
            document.body.style.overflow = '';
          }
        });
      })();
    </script>

    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"
    ></script>
    <script is:inline>
      /* ---- particles.js theme-aware initialization ---- */
      function buildParticlesConfig(isDark) {
        var color = isDark ? '#a8b2d8' : '#94a3b8';
        return {
          particles: {
            number: { value: 55, density: { enable: true, value_area: 900 } },
            color: { value: color },
            shape: { type: 'circle' },
            opacity: {
              value: isDark ? 0.35 : 0.45,
              random: true,
              anim: { enable: true, speed: 0.8, opacity_min: 0.05, sync: false },
            },
            size: { value: 2.5, random: true },
            line_linked: {
              enable: true,
              distance: 140,
              color: color,
              opacity: isDark ? 0.18 : 0.22,
              width: 1,
            },
            move: {
              enable: true, speed: 1.2, direction: 'none',
              random: true, straight: false, out_mode: 'out', bounce: false,
            },
          },
          interactivity: {
            detect_on: 'window',
            events: {
              onhover: { enable: !('ontouchstart' in window), mode: 'grab' },
              onclick: { enable: false },
              resize: true,
            },
            modes: {
              grab: { distance: 160, line_linked: { opacity: 0.45 } },
              push: { particles_nb: 3 },
            },
          },
          retina_detect: true,
        };
      }

      function initParticles() {
        var isDark = document.documentElement.getAttribute('data-theme') !== 'light';
        if (window.pJSDom && window.pJSDom.length > 0) {
          window.pJSDom[0].pJS.fn.vendors.destroypJS();
          window.pJSDom = [];
        }
        particlesJS('particles-js', buildParticlesConfig(isDark));
      }

      window.addEventListener('load', initParticles);

      /* テーマ変更イベントを受け取ってparticlesを再初期化 */
      window.addEventListener('theme-change', initParticles);
    </script>
  </body>
</html>
