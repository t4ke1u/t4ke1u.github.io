---







import { type Lang, ui } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].contact;
---

<section class="section" id="contact">
  <div class="container">
    <header class="section-header" data-animate>
      <span class="section-num">{t.sectionNum}</span>
      <h2 class="section-title">{t.sectionTitle}</h2>
      <div class="section-line"></div>
    </header>

    <div class="contact-body" data-animate>
      <p class="contact-eyebrow">{t.eyebrow}</p>
      <h3 class="contact-heading">{t.heading}</h3>
      <p class="contact-description">{t.description}</p>
      <div class="contact-actions">
        <a
          href="https://github.com/t4ke1u"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary"
        >
          {t.ctaGithub}
        </a>
        <a href="mailto:" class="btn btn--outline">{t.ctaSayHello}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-body {
    max-width: 600px;
    margin-inline: auto;
    text-align: center;
    padding: 2rem 0 4rem;
  }

  .contact-eyebrow {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .contact-heading {
    font-size: var(--fs-h1);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .contact-description {
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
  }

  .contact-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
