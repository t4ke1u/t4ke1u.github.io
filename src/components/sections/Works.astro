---



import { type Lang, ui } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].works;
---

<section class="section" id="works">
  <div class="container">
    <header class="section-header" data-animate>
      <span class="section-num">{t.sectionNum}</span>
      <h2 class="section-title">{t.sectionTitle}</h2>
      <div class="section-line"></div>
    </header>

    <div class="works-list">
      {t.projects.map((p, i) => (
        <article
          class={`project-card${p.featured ? ' project-card--featured' : ''}`}
          data-animate
          data-animate-delay={String((i % 2) + 1)}
        >
          <div class="project-meta">
            <span class="project-num">{p.num}.</span>
            <span class="project-category">{p.category}</span>
            <span class="project-period">{p.period}</span>
          </div>
          <h3 class="project-title">{p.title}</h3>
          <p class="project-description">{p.description}</p>
          <div class="project-footer">
            <div class="project-tech">
              {p.tech.map(t => <span class="tech-tag">{t}</span>)}
            </div>
            {p.links.length > 0 && (
              <div class="project-links">
                {p.links.map(link => (
                  <a href={link.href} target="_blank" rel="noopener noreferrer" class="project-link">
                    {link.label} ↗
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .works-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color 0.25s, transform 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .project-card:hover {
    border-color: rgba(100, 255, 218, 0.25);
    transform: translateY(-3px);
  }
  .project-card--featured {
    grid-column: span 2;
    border-color: rgba(100, 255, 218, 0.15);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .project-num {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: var(--fs-body-sm);
    color: var(--accent);
  }
  .project-category {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }
  .project-period {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--text-secondary);
    margin-left: auto;
  }

  .project-title {
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.35;
    transition: color 0.2s;
  }
  .project-card:hover .project-title { color: var(--accent); }

  .project-description {
    font-size: var(--fs-body-md);
    line-height: 1.75;
    color: var(--text-secondary);
    flex: 1;
  }

  .project-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tech-tag {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    background: rgba(100, 255, 218, 0.06);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    white-space: nowrap;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }
  .project-link {
    font-size: var(--fs-body-md);
    color: var(--text-secondary);
    transition: color 0.2s;
    white-space: nowrap;
  }
  .project-link:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .works-list { grid-template-columns: 1fr; }
    .project-card--featured { grid-column: span 1; }
  }
</style>
