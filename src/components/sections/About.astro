---







import { type Lang, ui } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].about;
---

<section class="section" id="about">
  <div class="container">
    <header class="section-header" data-animate>
      <span class="section-num">{t.sectionNum}</span>
      <h2 class="section-title">{t.sectionTitle}</h2>
      <div class="section-line"></div>
    </header>

    <div class="about-layout">
      <div class="about-text" data-animate>
        {t.body.map(para => <p set:html={para} />)}
        <div class="interests">
          <span class="interests-label">{t.interestsLabel}</span>
          <div class="interest-chips">
            {t.interests.map(i => (
              <span class="interest-chip">
                <span class="interest-name">{i.name}</span>
                {i.note && <span class="interest-note">{i.note}</span>}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div class="timeline" data-animate data-animate-delay="2">
        {t.timeline.map((item) => (
          <div class={`timeline-item${item.accent ? ' timeline-item--accent' : ''}`}>
            <span class="timeline-date">{item.date}</span>
            <div class="timeline-dot"></div>
            <div class="timeline-body">
              <p class="timeline-title">{item.title}</p>
              <p class="timeline-sub">{item.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .about-text p {
    font-size: var(--fs-body);
    line-height: 1.85;
    color: var(--text-secondary);
  }
  :global(.highlight) {
    color: var(--accent);
    font-weight: 500;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--border);
    padding-left: 1.75rem;
    position: relative;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    align-items: start;
    gap: 0 1rem;
    padding-bottom: 1.75rem;
    position: relative;
  }
  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-date {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--text-secondary);
    padding-top: 0.15rem;
    text-align: right;
    white-space: nowrap;
  }
  .timeline-item--accent .timeline-date { color: var(--accent); }

  .timeline-dot {
    position: absolute;
    left: calc(-1.75rem - 4px);
    top: 0.35rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-secondary);
    border: 1px solid var(--bg);
  }
  .timeline-item--accent .timeline-dot { background: var(--accent); }

  .timeline-title {
    font-size: var(--fs-h3);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 0.2rem;
  }
  .timeline-sub {
    font-size: var(--fs-body-md);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ── Interests ─────────────────────────────────── */
  .interests {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }

  .interests-label {
    display: block;
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .interest-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .interest-chip {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0.875rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color 0.2s;
  }
  .interest-chip:hover { border-color: rgba(100, 255, 218, 0.25); }

  .interest-name {
    font-size: var(--fs-body);
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
  }

  .interest-note {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
