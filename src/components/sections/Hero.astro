---







import { Image } from 'astro:assets';
import imgAutumnTemple           from '../../assets/images/autumn-temple-gate.jpg';
import imgAutumnTrain            from '../../assets/images/autumn-train-forest.jpg';
import imgLighthouse             from '../../assets/images/coastal-cape-lighthouse.jpg';
import imgHakoneTorii            from '../../assets/images/hakone-torii-lake.jpg';
import imgWarehouse              from '../../assets/images/historic-warehouse-corridor.jpg';
import imgNachiPagoda            from '../../assets/images/nachi-pagoda-waterfall.jpg';
import imgNotreDame              from '../../assets/images/notre-dame-cathedral.jpg';
import imgOceanSunset           from '../../assets/images/ocean-sunset.jpg';
import imgShibazakura            from '../../assets/images/shibazakura-torii.jpg';
import imgSunsetSilhouette       from '../../assets/images/sunset-reflection-silhouette.jpg';
import { type Lang, ui } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].hero;

const col1 = [
  { src: imgOceanSunset,     alt: '' },
  { src: imgNotreDame,       alt: '' },
  { src: imgAutumnTemple,    alt: '' },
  { src: imgLighthouse,      alt: '' },
  { src: imgHakoneTorii,     alt: '' },
];
const col2 = [
  { src: imgShibazakura,     alt: '' },
  { src: imgNachiPagoda,     alt: '' },
  { src: imgWarehouse,       alt: '' },
  { src: imgAutumnTrain,     alt: '' },
  { src: imgSunsetSilhouette, alt: '' },
];

const loop1 = [...col1, ...col1];
const loop2 = [...col2, ...col2];
---

<section class="hero" id="home">
  <div class="hero-content">
    <p class="hero-greeting" data-animate data-animate-delay="1">{t.greeting}</p>
    <h1 class="hero-name"    data-animate data-animate-delay="2">{t.name}</h1>
    <p class="hero-tagline"  data-animate data-animate-delay="3">{t.tagline}</p>
    <div class="hero-actions" data-animate data-animate-delay="4">
      <a href="#works" class="btn btn--primary">{t.ctaWork}</a>
    </div>
  </div>

  <div class="hero-photos" aria-hidden="true">
    <div class="photo-col photo-col--down">
      {loop1.map((p) => (
        <div class="photo-item">
          <Image src={p.src} alt={p.alt} widths={[400, 800]} sizes="(max-width: 900px) 160px, 220px" loading="eager" />
        </div>
      ))}
    </div>
    <div class="photo-col photo-col--up">
      {loop2.map((p) => (
        <div class="photo-item">
          <Image src={p.src} alt={p.alt} widths={[400, 800]} sizes="(max-width: 900px) 160px, 220px" loading="eager" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Hero layout ───────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(var(--nav-height) + 2rem) 2rem 4rem;
  }

  /* ── Text ──────────────────────────────────────── */
  .hero-content { display: flex; flex-direction: column; }

  .hero-greeting {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 1.25rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ── Photo carousel ────────────────────────────── */
  .hero-photos {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;   /* 列をコンテンツ高さのまま保持 → -50% が正確に一周分になる */
    gap: 0.75rem;
    height: 580px;
    overflow: hidden;
    transform: translateZ(0); /* iOS: overflow:hidden が transform アニメーション中も機能するよう GPU レイヤーに昇格 */
    -webkit-transform: translateZ(0);
  }

  .hero-photos::before,
  .hero-photos::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    height: 110px;
    z-index: 2;
    pointer-events: none;
  }
  .hero-photos::before {
    top: 0;
    background: linear-gradient(to bottom, var(--bg) 0%, transparent 100%);
  }
  .hero-photos::after {
    bottom: 0;
    background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
  }

  .photo-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    will-change: transform;
  }

  .photo-col--down { animation: colDown 32s linear infinite; }
  .photo-col--up   { animation: colUp   22s linear infinite; }

  @keyframes colDown {
    from { transform: translateY(-50%); }
    to   { transform: translateY(0%);   }
  }
  @keyframes colUp {
    from { transform: translateY(0%);   }
    to   { transform: translateY(-50%); }
  }

  .photo-item {
    width: 100%;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .photo-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-top: calc(var(--nav-height) + 2rem);
    }
    .hero-photos { height: 340px; }
  }

  @media (max-width: 480px) {
    .hero-photos { height: 260px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-col { animation: none; }
  }
</style>

