---
---
<section class="hero" id="home">
  <p class="hero-greeting" data-animate data-animate-delay="1">Hi, my name is</p>
  <h1 class="hero-name" data-animate data-animate-delay="2">Takeru Ota.</h1>
  <h2 class="hero-tagline" data-animate data-animate-delay="3">
    I build full-stack systems —<br />
    from quantum circuits to mobile apps.
  </h2>
  <p class="hero-description" data-animate data-animate-delay="4">
    Software engineer at Sony Honda Mobility, M.Eng. from Waseda University.
    Bridging quantum computing research and real-world product engineering
    across backend, frontend, cloud, and mobile.
  </p>
  <div class="hero-actions" data-animate data-animate-delay="5">
    <a href="#works" class="btn btn--primary">View my work</a>
    <a href="#contact" class="btn btn--outline">Get in touch</a>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(var(--nav-height) + 3rem) 2rem 4rem;
  }

  .hero-greeting {
    font-size: var(--fs-body-sm);   /* 10pt 本文（小さめ） */
    font-weight: 400;
    color: var(--accent);
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-size: var(--fs-title);     /* 32pt タイトル */
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.05;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-size: var(--fs-h1);        /* 24pt 大見出し */
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.25;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }

  .hero-description {
    max-width: 520px;
    font-size: var(--fs-body);      /* 14pt 本文 */
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
