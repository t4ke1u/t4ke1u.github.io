---
import { ui, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].skills;
---

<section class="section" id="skills">
  <div class="container">
    <header class="section-header" data-animate>
      <span class="section-num">{t.sectionNum}</span>
      <h2 class="section-title">{t.sectionTitle}</h2>
      <div class="section-line"></div>
    </header>

    <div class="skills-grid">
      {t.categories.map((cat, i) => (
        <div class="skill-category" data-animate data-animate-delay={String(i % 3 + 1)}>
          <h3 class="category-label">{cat.label}</h3>
          <div class="skill-tags">
            {cat.skills.map(skill => (
              <span class="tag">
                {skill.name}
                {skill.years && <span class="tag-years">{skill.years}</span>}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .category-label {
    font-size: var(--fs-h3);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
    font-size: var(--fs-body-md);
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 3px;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .tag:hover {
    color: var(--text-primary);
    border-color: rgba(168, 178, 216, 0.25);
  }

  .tag-years {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    opacity: 0.8;
  }

  @media (max-width: 900px) { .skills-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .skills-grid { grid-template-columns: 1fr; } }
</style>
