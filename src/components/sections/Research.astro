---







import { type Lang, ui } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].research;
---

<section class="section" id="research">
  <div class="container">
    <header class="section-header" data-animate>
      <span class="section-num">{t.sectionNum}</span>
      <h2 class="section-title">{t.sectionTitle}</h2>
      <div class="section-line"></div>
    </header>

    <div class="research-layout">
      <div class="research-overview" data-animate>
        <h3 class="overview-title">{t.overviewTitle}</h3>
        {t.body.map(para => <p set:html={para} />)}
        <p class="research-stats">
          {t.statsNums.map((num, i) => (
            <>
              <span class="stat">
                <span class="stat-num">{num}</span>
                {t.statsLabels[i]}
              </span>
              {i < t.statsNums.length - 1 && <span class="stat-sep">/</span>}
            </>
          ))}
        </p>
        <a
          href="https://ieeexplore.ieee.org/author/308719292671247"
          target="_blank"
          rel="noopener noreferrer"
          class="ieee-link"
        >
          {t.ieeeLabel}
        </a>
      </div>

      <div class="research-right">
        <div class="awards" data-animate data-animate-delay="2">
          <h4 class="sub-heading">{t.awardsTitle}</h4>
          <ul class="award-list">
            {t.awards.map(a => (
              <li class="award-item">
                <div class="award-dot"></div>
                <div>
                  <p class="award-title">{a.title}</p>
                  <p class="award-org">{a.org} · {a.year}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div class="publications" data-animate data-animate-delay="3">
          <h4 class="sub-heading">{t.papersTitle}</h4>
          <ul class="paper-list">
            {t.papers.map(p => (
              <li class="paper-item">
                <span class="paper-type">{p.type}</span>
                <div class="paper-body">
                  {p.doi
                    ? <a href={p.doi} target="_blank" rel="noopener noreferrer" class="paper-title">{p.title} ↗</a>
                    : <p class="paper-title">{p.title}</p>
                  }
                  <p class="paper-meta">{p.authors} — {p.venue}</p>
                </div>
              </li>
            ))}
          </ul>
          <button class="all-papers-btn" type="button" data-modal-open="rmodal-all-papers">
            {t.allPapersLabel} ↗
          </button>
          <a class="all-papers-link" href={lang === 'en' ? '/en/research/publications' : '/research/publications'}>
            {t.allPapersLabel} ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- All papers modal -->
<dialog id="rmodal-all-papers" class="rmodal">
  <div class="rmodal-inner">
    <div class="rmodal-header">
      <h3 class="rmodal-title">{t.allPapersModalTitle}</h3>
      <button class="rmodal-close" type="button" data-modal-close aria-label="Close">✕</button>
    </div>
    <div class="rmodal-body">
      {t.allPaperCategories.map(cat => (
        <div class="rmodal-category">
          <h4 class="rmodal-category-heading">{cat.heading}</h4>
          <ul class="rmodal-paper-list">
            {cat.items.map(item => (
              <li class="rmodal-paper-item">
                {item.doi
                  ? <a href={item.doi} target="_blank" rel="noopener noreferrer" class="rmodal-paper-title">{item.title} ↗</a>
                  : <p class="rmodal-paper-title">{item.title}</p>
                }
                <p class="rmodal-paper-meta">{item.authors} — {item.venue}</p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</dialog>

<style>
  .research-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .overview-title {
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }
  .research-overview p {
    font-size: var(--fs-body);
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
  .research-overview em { font-style: italic; }
  .research-overview strong { color: var(--text-primary); font-weight: 500; }
  :global(.highlight) { color: var(--accent); font-weight: 600; }

  .research-overview .research-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.25rem;
  }
  .stat { font-size: var(--fs-body-md); color: var(--text-secondary); }
  .stat-num {
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--accent);
    font-family: 'SF Mono', 'Fira Code', monospace;
    line-height: 1;
    margin-right: 0.25rem;
  }
  .stat-sep { color: var(--border); }

  .ieee-link {
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    transition: opacity 0.2s;
  }
  .ieee-link:hover { opacity: 0.7; }

  .research-right {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .sub-heading {
    font-size: var(--fs-h3);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'SF Mono', 'Fira Code', monospace;
    margin-bottom: 1rem;
  }

  .award-list { display: flex; flex-direction: column; gap: 1rem; }
  .award-item { display: flex; align-items: flex-start; gap: 0.75rem; }
  .award-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); margin-top: 0.45rem; flex-shrink: 0;
  }
  .award-title {
    font-size: var(--fs-h3); font-weight: 500;
    color: var(--text-primary); line-height: 1.4; margin-bottom: 0.15rem;
  }
  .award-org { font-size: var(--fs-body-sm); color: var(--text-secondary); }

  .paper-list { display: flex; flex-direction: column; gap: 1.1rem; }
  .paper-item {
    display: grid; grid-template-columns: 5.5rem 1fr;
    gap: 0.75rem; align-items: start;
    padding-bottom: 1.1rem; border-bottom: 1px solid var(--border);
  }
  .paper-item:last-child { border-bottom: none; padding-bottom: 0; }
  .paper-type {
    font-size: var(--fs-body-sm); font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent); background: rgba(100, 255, 218, 0.07);
    padding: 0.2rem 0.4rem; border-radius: 2px;
    white-space: nowrap; text-align: center; margin-top: 0.1rem; display: block;
  }
  .paper-title {
    font-size: var(--fs-body-md); color: var(--text-primary);
    line-height: 1.5; margin-bottom: 0.25rem; transition: color 0.2s;
  }
  a.paper-title:hover { color: var(--accent); }
  .paper-meta { font-size: var(--fs-body-sm); color: var(--text-secondary); line-height: 1.5; }

  .all-papers-btn,
  .all-papers-link {
    margin-top: 1.25rem;
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    padding: 0;
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent);
    cursor: pointer;
    transition: opacity 0.2s;
    letter-spacing: 0.05em;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .all-papers-btn:hover,
  .all-papers-link:hover { opacity: 0.7; }

  @media (min-width: 769px) {
    .all-papers-link { display: none; }
  }
  @media (max-width: 768px) {
    .all-papers-btn  { display: none; }
    .all-papers-link { display: inline; }
  }

  /* ── Research modal ──────────────────────────────── */
  .rmodal {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    max-width: 720px;
    width: 90vw;
    max-height: 82vh;
    padding: 0;
    color: var(--text-primary);
    margin: auto; /* restore UA centering overridden by global margin:0 reset */
  }
  .rmodal[open] {
    display: flex;
    flex-direction: column;
  }
  .rmodal::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .rmodal-inner {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  .rmodal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 2rem 1.25rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0; gap: 1rem;
  }
  .rmodal-title {
    font-size: var(--fs-h2); font-weight: 600; color: var(--text-primary);
  }
  .rmodal-close {
    background: none; border: none; color: var(--text-secondary);
    font-size: 1rem; cursor: pointer; padding: 0.25rem 0.5rem;
    border-radius: 2px; transition: color 0.2s; line-height: 1; flex-shrink: 0;
  }
  .rmodal-close:hover { color: var(--text-primary); }

  .rmodal-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 1.5rem 2rem 2rem;
    display: flex; flex-direction: column; gap: 2rem;
  }

  .rmodal-category { display: flex; flex-direction: column; gap: 0.75rem; }
  .rmodal-category-heading {
    font-size: var(--fs-body-sm); font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
  }

  .rmodal-paper-list { display: flex; flex-direction: column; gap: 0.9rem; }
  .rmodal-paper-item {
    padding-left: 0.75rem; border-left: 2px solid var(--border);
  }
  .rmodal-paper-title {
    font-size: var(--fs-body-md); color: var(--text-primary);
    line-height: 1.5; margin-bottom: 0.2rem; transition: color 0.2s;
    display: block;
  }
  a.rmodal-paper-title:hover { color: var(--accent); }
  .rmodal-paper-meta {
    font-size: var(--fs-body-sm); color: var(--text-secondary); line-height: 1.5;
  }

  @media (max-width: 900px) {
    .research-layout { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 480px) {
    .rmodal-header { padding: 1.25rem; }
    .rmodal-body { padding: 1.25rem; }
  }
</style>
