---
import { ui, type Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang].nav;

const navLinks = [
  { href: '#about',    label: 'About'    },
  { href: '#skills',   label: 'Skills'   },
  { href: '#works',    label: 'Works'    },
  { href: '#research', label: 'Research' },
];
---

<nav class="nav" id="nav">
  <div class="nav-inner">

    <!-- 左: デスクトップのみ空スペース (グリッドの均衡用) -->
    <div class="nav-spacer"></div>

    <!-- 中央: pill 型ナビ (デスクトップのみ) -->
    <ul class="nav-pill">
      {navLinks.map(({ href, label }) => (
        <li><a href={href} class="pill-link">{label}</a></li>
      ))}
    </ul>

    <!-- 右: コントロール -->
    <div class="nav-controls">
      <!-- テーマトグル (デスクトップ) -->
      <button class="ctrl-btn theme-btn" data-theme-toggle aria-label="テーマを切り替える">
        <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1"  x2="12" y2="3"/>  <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>  <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- 言語トグル (デスクトップ) -->
      <a href={t.langHref} class="ctrl-btn lang-btn" aria-label="Switch language">
        {t.langLabel}
      </a>

      <!-- ハンバーガー (モバイルのみ) -->
      <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul class="mobile-links">
      {navLinks.map(({ href, label }) => (
        <li><a href={href} class="mobile-link">{label}</a></li>
      ))}
    </ul>

    <!-- モバイル内のユーティリティ -->
    <div class="mobile-utils">
      <button class="mobile-util-btn" data-theme-toggle>
        <span class="util-icon">
          <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/> <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/> <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="theme-label-for-dark">Light Mode</span>
        <span class="theme-label-for-light">Dark Mode</span>
      </button>

      <a href={t.langHref} class="mobile-util-btn">
        <span class="util-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </span>
        {t.langLabel}
      </a>
    </div>
  </div>
</nav>

<style>
  /* ── Nav wrapper ────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 100;
    background: transparent;
  }

  /* ── Inner grid: [spacer] [pill] [controls] ─────── */
  .nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 2rem;
    height: var(--nav-height);
  }

  .nav-spacer { /* 左の空きスペース */ }

  /* ── Pill nav ───────────────────────────────────── */
  .nav-pill {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.3rem 0.4rem;
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    border-radius: 9999px;
    box-shadow: 0 4px 24px var(--pill-shadow);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background 0.25s, border-color 0.25s, box-shadow 0.25s;
    list-style: none;
  }

  .pill-link {
    display: block;
    padding: 0.38rem 0.9rem;
    font-size: var(--fs-body-sm);
    font-weight: 400;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    border-radius: 9999px;
    transition: background 0.18s, color 0.18s;
    white-space: nowrap;
  }
  .pill-link:hover {
    background: var(--pill-link-hover-bg);
    color: var(--accent);
  }

  /* ── Right controls ─────────────────────────────── */
  .nav-controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  /* Shared base for theme + lang buttons */
  .ctrl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 34px;
    border-radius: 9999px;
    cursor: pointer;
    color: var(--text-secondary);
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  .ctrl-btn:hover { color: var(--accent); }

  .theme-btn {
    width: 34px;
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .theme-btn:hover { border-color: var(--accent); background: var(--pill-link-hover-bg); }

  .lang-btn {
    padding-inline: 0.75rem;
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.08em;
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .lang-btn:hover { border-color: var(--accent); background: var(--pill-link-hover-bg); }

  /* ── Hamburger (mobile only) ────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 34px;
    height: 34px;
    padding: 0;
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    border-radius: 9999px;
    cursor: pointer;
    color: var(--text-secondary);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .hamburger:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--pill-link-hover-bg);
  }
  .hamburger span {
    display: block;
    width: 14px;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  .hamburger.is-open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  /* ── Mobile menu ────────────────────────────────── */
  .mobile-menu {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
    background: var(--nav-bg);
  }
  .mobile-menu.is-open {
    max-height: 440px;
    border-bottom: 1px solid var(--border);
  }

  .mobile-links {
    padding: 1rem 2rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
  }
  .mobile-link {
    display: block;
    padding: 0.7rem 0;
    font-size: var(--fs-body);
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s, padding-left 0.2s;
  }
  .mobile-link:hover { color: var(--accent); padding-left: 0.4rem; }
  .mobile-links li:last-child .mobile-link { border-bottom: none; }

  /* Mobile utility row */
  .mobile-utils {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 2rem 1.5rem;
    border-top: 1px solid var(--border);
  }
  .mobile-util-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 0;
    font-size: var(--fs-body-sm);
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--text-secondary);
    background: none;
    border: 1px solid var(--border);
    border-radius: 9999px;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .mobile-util-btn:hover { color: var(--accent); border-color: var(--accent); }

  .util-icon { display: flex; align-items: center; }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-inner {
      display: flex;
      justify-content: flex-end;
      height: auto;
      padding-block: 0.75rem;
    }
    .nav-spacer { display: none; }
    .nav-pill   { display: none; }
    .theme-btn,
    .lang-btn   { display: none; }
    .hamburger  { display: flex; }
    .mobile-menu { display: block; }

    .nav.menu-open {
      background: var(--nav-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  }
</style>

<style is:global>
  /* ── CSS 変数: pill の色はテーマで変わる ─────────── */
  :root {
    --pill-bg:              rgba(255, 255, 255, 0.05);
    --pill-border:          rgba(168, 178, 216, 0.18);
    --pill-shadow:          rgba(0, 0, 0, 0.25);
    --pill-link-hover-bg:   rgba(91, 200, 255, 0.10);
  }
  [data-theme="light"] {
    --pill-bg:              rgba(0, 0, 0, 0.04);
    --pill-border:          rgba(17, 24, 39, 0.14);
    --pill-shadow:          rgba(0, 0, 0, 0.08);
    --pill-link-hover-bg:   rgba(2, 132, 199, 0.08);
  }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme="dark"]) {
      --pill-bg:            rgba(0, 0, 0, 0.04);
      --pill-border:        rgba(17, 24, 39, 0.14);
      --pill-shadow:        rgba(0, 0, 0, 0.08);
      --pill-link-hover-bg: rgba(2, 132, 199, 0.08);
    }
  }

  /* ── Mobile theme label visibility ──────────────── */
  .theme-label-for-dark  { display: inline; }
  .theme-label-for-light { display: none; }
  [data-theme="light"] .theme-label-for-dark  { display: none; }
  [data-theme="light"] .theme-label-for-light { display: inline; }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme="dark"]) .theme-label-for-dark  { display: none; }
    :root:not([data-theme="dark"]) .theme-label-for-light { display: inline; }
  }
</style>

<script>
  /* ---- Hamburger ---- */
  const hamburger  = document.getElementById('hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const nav        = document.getElementById('nav') as HTMLElement | null;

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('is-open');
    mobileMenu?.classList.toggle('is-open');
    nav?.classList.toggle('menu-open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('is-open');
      mobileMenu?.classList.remove('is-open');
      nav?.classList.remove('menu-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
    });
  });

  /* ---- Theme toggle (desktop + mobile) ---- */
  function applyThemeToggle() {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme') ?? 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    html.classList.add('theme-transitioning');
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    window.dispatchEvent(new CustomEvent('theme-change'));
    setTimeout(() => html.classList.remove('theme-transitioning'), 300);
  }

  document.querySelectorAll('[data-theme-toggle]').forEach(btn => {
    btn.addEventListener('click', applyThemeToggle);
  });

</script>
